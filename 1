# Install packages (run once)
install.packages(c("ARDL","tseries","lmtest"))
# Load libraries
library(ARDL)
library(tseries)
library(lmtest)
# Load data (example dataset)
data(denmark)
df <- denmark
# Step 1: Unit root test (check stationarity)
adf.test(df$LRM)
adf.test(diff(df$LRM))
adf.test(df$LRY)
adf.test(diff(df$LRY))
adf.test(df$IBO)
adf.test(diff(df$IBO))
adf.test(df$IDE)
adf.test(diff(df$IDE))
# Step 2: ARDL model selection
model <- LRM ~ LRY + IBO + IDE
ardl_model <- auto_ardl(model, data = df, max_order = c(5,4,4,4))
summary(ardl_model)
# Step 3: Bounds test (cointegration)
bounds_f_test(ardl_model$best_model, case = 3)
# Step 4: Long-run relationship
multipliers(ardl_model$best_model)
# Step 5: Short-run dynamics (ECM)
ecm <- uecm(ardl_model$best_model)
summary(ecm)
# Step 6: Diagnostics
bgtest(ardl_model$best_model)                 # autocorrelation
bptest(ardl_model$best_model)                 # heteroskedasticity
jarque.bera.test(residuals(ardl_model$best_model))  # normality
