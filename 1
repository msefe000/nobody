install.packages(c("plm","dplyr"))
# Load libraries
library(plm)
library(dplyr)
# Load data
data <- read.csv("C:/Econometrics/DataR/JTRAIN.csv")
# Keep required variables
df <- data %>%
  select(fcode, year, lscrap, tothrs, d88, d89, grant, grant_1) %>%
  na.omit()
# Convert to panel data
pdata <- pdata.frame(df, index = c("fcode","year"))
# 1. Pooled OLS
ols <- plm(lscrap ~ tothrs + d88 + d89 + grant + grant_1,
           data = pdata, model = "pooling")
summary(ols)
# 2. Fixed Effects (FE)
fe <- plm(lscrap ~ tothrs + d88 + d89 + grant + grant_1,
          data = pdata, model = "within")
summary(fe)
# 3. Random Effects (RE)
re <- plm(lscrap ~ tothrs + d88 + d89 + grant + grant_1,
          data = pdata, model = "random")
summary(re)
# 4. Hausman Test
phtest(fe, re)
# 5. Between Estimator
be <- plm(lscrap ~ tothrs + grant,
          data = pdata, model = "between")
summary(be)
# 6. First Difference Model
df <- df %>%
  group_by(fcode) %>%
  mutate(dlscrap = lscrap - lag(lscrap),
         dtothrs = tothrs - lag(tothrs),
         dgrant  = grant - lag(grant)) %>%
  na.omit()
fd <- lm(dlscrap ~ dtothrs + dgrant, data = df)
summary(fd)

