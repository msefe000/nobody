# Load libraries
library(rugarch)
library(tseries)
library(FinTS)
# Load your dataset
data <- read.csv("C:/Users/MAHE/Downloads/nifty.csv")
# Convert closing price to numeric (if needed)
price <- as.numeric(data$Close)
# Step 1: Calculate Returns (log returns preferred)
returns <- diff(log(price))
# Remove NA
returns <- na.omit(returns)
# Plot returns
plot.ts(returns, main="NIFTY Returns")
# Step 2: Check ARCH effect
ArchTest(returns, lags = 5)
# Step 3: Fit GARCH(1,1) Model
spec <- ugarchspec(
  variance.model = list(model = "sGARCH", garchOrder = c(1,1)),
  mean.model = list(armaOrder = c(0,0)),
  distribution.model = "std"
)
fit <- ugarchfit(spec = spec, data = returns)
show(fit)
# Step 4: Diagnostics
plot(fit)
infocriteria(fit)
# Step 5: Forecast volatility
forecast <- ugarchforecast(fit, n.ahead = 10)
# Plot predicted volatility
plot(sigma(forecast))
print(forecast)
