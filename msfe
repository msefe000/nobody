infocriteria(fit)
### Advanced ARCH Modeling with (Using rugarch) 
#The rugarch package is the modern standard for volatility modeling. 
#An ARCH(q) model is a GARCH model where the GARCH order is 0.
#garchOrder = c(q, 0) defines an ARCH model of order q.
#ARCH(q): Relates current volatility to past squared returns.
#GARCH(p, q): Relates current volatility to both past squared returns and past volatilities. 

# 1. Specify the GARCH(1,1) model
# variance.model: We choose a standard GARCH ('sGARCH') with order (1,1)
# mean.model: We assume a constant mean (ARIMA(0,0))
# distribution.model: We use the Student's t-distribution ('std')
garch_spec <- ugarchspec(
  variance.model = list(model = "sGARCH", garchOrder = c(1, 1)),
  mean.model     = list(armaOrder = c(0, 0), include.mean = TRUE),
  distribution.model = "norm"
)
# 2. Fit the model 
garch_fit <- ugarchfit(spec = garch_spec, data = returns)

# 3. Print the summary of the results
# This output provides the estimated coefficients, standard errors, and significance tests
print(garch_fit)

# 4.Volatility Forecasting 
# Forecast volatility for the next 10 periods
forecast <- ugarchforecast(fit, n.ahead = 10)

# Extract and plot the predicted sigma (standard deviation)
plot(sigma(forecast))
print(forecast)
