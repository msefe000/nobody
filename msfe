res <- residuals(ardl_model_selected$best_model)
n <- length(res)
cusum <- cumsum(res / sd(res))  # CUSUM (parameter stability)
cusum_sq <- cumsum(res^2) / sum(res^2) # CUSUMSQ (variance stability)
par(mfrow=c(2,1))
plot(1:n, cusum, type="l", main="CUSUM Test", ylab="CUSUM", xlab="Time", col="blue", lwd=2)
abline(h=c(-3,3), col="red", lty=2, lwd=2)
plot(1:n, cusum_sq, type="l", main="CUSUMSQ Test", ylab="CUSUMSQ", xlab="Time", col="blue", lwd=2)
