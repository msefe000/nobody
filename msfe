### ARCH Effect Test (LM Test):  to check if ARCH effects exist in data.
# Perform Lagrange Multiplier (LM) test for ARCH effects
# H0: No ARCH effects
ArchTest(returns, lags = 1)
# If p-value < 0.05, ARCH effects are present.

# Fit an ARCH(1) model: order = c(GARCH_lag, ARCH_lag)
# For ARCH(1), set GARCH lag to 0 and ARCH lag to 1
arch_model <- garch(returns, order = c(0, 1))

# Summary of the model
summary(arch_model)

# Also Specify the ARCH(1) model
# garchOrder = c(1, 0) defines an ARCH(1) model
spec <- ugarchspec(
  variance.model = list(model = "sGARCH", garchOrder = c(1, 0)),
  mean.model = list(armaOrder = c(0, 0), include.mean = TRUE),
  distribution.model = "norm"
)

# Fit the model to your data
fit <- ugarchfit(spec = spec, data = returns)

# View the results (coefficients, p-values, and info criteria)
show(fit)

# Forecast the next 5 periods
forecast <- ugarchforecast(fit, n.ahead = 5)
print(forecast)

# Diagnostic Tests
