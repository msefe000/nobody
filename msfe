##Step 2: Unit Root Tests
##Before running the ARDL model, it is a crucial to confirm that none of your variables are integrated of order I(2) or higher. Variables can be I(0), I(1), or a combination of both. You can use the Augmented Dickey-Fuller (ADF) or Phillips-Perron (PP) tests.
adf.test(denmark$LRM)
adf.test(diff(denmark$LRM))
adf.test(denmark$LRY)
adf.test(diff(denmark$LRY))
adf.test(denmark$LPY)
adf.test(diff(denmark$LPY))
adf.test(denmark$IBO)
adf.test(diff(denmark$IBO))
adf.test(denmark$IDE)
adf.test(diff(denmark$IDE))

##Step 3: Optimal Lag Selection and Model Estimation
# Define the model formula (e.g., LRM as dependent, LRY, IBO, IDE as independent)
model <- LRM ~ LRY + IBO + IDE

# Automatically select the optimal ARDL model based on AIC or BIC
# maxlag sets the maximum possible lag for each variable
ardl_model_selected <- auto_ardl(model, data = denmark, max_order = c(5,4,4,4))

# View the summary of the selected optimal model
summary(ardl_model_selected)

# The output shows the optimal lags chosen for each variable (e.g., ARDL(p, q1, ..., qk))
# You can view the chosen lags directly
# ardl_model_selected$selection

##Step 4: Cointegration (Bounds) Test
##Pesaran-Shin-Smith test checks for cointegration when variables are I(0), I(1), or mixed, without pre-testing stationarity.
# The 'case' parameter depends on the deterministic components (intercept and/or trend) in your model
# Case 3 (unrestricted intercept, no trend) is common, but adjust as needed.

bounds_f_test(ardl_model_selected$best_model, case = 3)

# You can also perform the t-bounds test
bounds_t_test(ardl_model_selected$best_model, case = 3)

##Interpretation:
#F/t-statistic < lower I(0) bound: No cointegration.(fail to reject H0)
#F/t-statistic > upper I(1) bound: Cointegration exists. (reject H0: no cointegration)
#Between bounds: Inconclusive

##Step 5: Long-Run and Short-Run Analysis
##If cointegration is confirmed, you can analyze the long-run multipliers and the short-run dynamics (Error Correction Model, ECM). 
# Extract the long-run coefficients
long_run <- multipliers(ardl_model_selected$best_model)
print(long_run)

#Error Correction Model (ECM): The uecm() function estimates the unrestricted error correction form. The coefficient on the lagged dependent variable (the error correction term, ECT) should be negative and statistically significant. 
# Estimate the Unrestricted ECM
uecm_model <- uecm(ardl_model_selected$best_model)
summary(uecm_model)

##Step 6: Post-Estimation Diagnostics on the residuals to ensure the model's validity.
# Check for autocorrelation (Breusch-Godfrey LM test)
#p-value > 0.05: No autocorrelation (fail to reject H0)
#p-value < 0.05: Autocorrelation present

bgtest(ardl_model_selected$best_model, order = 3)

# Check for heteroskedasticity (Breusch-Pagan)
bptest(ardl_model_selected$best_model)

#Check Normality (Jarque-Bera)
jarque.bera.test(residuals(ardl_model_selected$best_model))

# Check for parameter stability (CUSUM or CUSUMSQ tests)
